{
    "--att-spec": {
        "type": "filename",
        "description": "Path to attacker specification (.atdl file)",
        "extension": ".atdl",
        "validation": { "must_exists": true },
        "default": "/home/alvie/spec-lib/example/attacker.atdl",
        "required": true
    },
    "--encl-spec": {
        "type": "filename",
        "description": "Path to enclave specification (.etdl file)",
        "extension": ".etdl",
        "validation": { "must_exists": true },
        "default": "/home/alvie/spec-lib/example/enclave.etdl",
        "required": true
    },
    "--oracle": {
        "type": "choice",
        "description": "Oracle that must be used for equivalence check",
        "values": ["randomwalk", "pac", "exhaustive"],
        "required": true
    },
    "--tmpdir": {
        "type": "directory",
        "description": "Temporary directory where intermediate results/files will be stored",
        "validation": { "must_exists": false },
        "default": "/tmp/alvie",
        "required": true
    },
    "--res": {
        "type": "filename",
        "description": "File where the final learned model will be stored (.dot file)",
        "extension": ".dot",
        "validation": { "must_exists": false },
        "default": "/tmp/alvie/result.dot",
        "required": true
    },
    "--sancus": {
        "type": "directory",
        "description": "Directory where the sancus-core-gap repository was cloned",
        "validation": { "must_exists": true },
        "default": "/home/alvie/sancus-core-gap",
        "required": true
    },
    "--secret": {
        "type": "int",
        "description": "Provide a secret value. Required if the enclave specification contains a secret variable '?'.",
        "default": "0",
        "required": false
    },
    "--step-limit": {
        "type": "int",
        "description": "Max steps per random walk / PAC sample",
        "default": "200",
        "required": false
    },
    "--debug": {
        "type": "boolean",
        "description": "Enable debug-level logging",
        "required": false
    },
    "--info": {
        "type": "boolean",
        "description": "Enable info-level logging",
        "required": false
    },
    "--m1-int": {
        "type": "filename",
        "extension": ".dot",
        "description": "Path to first Mealy machine model (.dot file) (interrupt variant)",
        "default": "/tmp/alvie/m1_int.dot",
        "validation": { "must_exists": true },
        "required": true
    },
    "--m2-int": {
        "type": "filename",
        "extension": ".dot",
        "description": "Path to second Mealy machine model (.dot file) (interrupt variant)",
        "default": "/tmp/alvie/m2_int.dot",
        "validation": { "must_exists": true },
        "required": true
    },
    "--m1-nint": {
        "type": "filename",
        "extension": ".dot",
        "description": "Path to first Mealy machine model (.dot file) (non-interrupt variant)",
        "default": "/tmp/alvie/m1_nint.dot",
        "validation": { "must_exists": true },
        "required": true
    },
    "--m2-nint": {
        "type": "filename",
        "extension": ".dot",
        "description": "Path to second Mealy machine model (.dot file) (non-interrupt variant)",
        "default": "/tmp/alvie/m2_nint.dot",
        "validation": { "must_exists": true },
        "required": true
    },
    "--witness-file-basename": {
        "type": "directory",
        "description": "Output path prefix",
        "validation": { "must_exists": false },
        "default": "/tmp/alvie/witness",
        "required": true
    },
    "--cex-limit": {
        "type": "int",
        "description": "Number of counterexamples to enumerate",
        "default": "1",
        "required": false
    },
    "--sexp-input": {
        "type": "filename",
        "description": "Symbolic expression representing the raw input for the simulator"
    },
    "--commit": {
        "type": "hash",
        "description": "Simulator git commit to use",
        "required": false
    },
    "--ignore-interrupts": {
        "type": "boolean",
        "description": "Collapse interrupt outputs",
        "required": false
    },
    "--sancus-master-key": {
        "type": "hex",
        "description": "Master key",
        "default": "cafe",
        "required": false
    },
    "--att-spec1": {
        "type": "filename",
        "description": "Path to first attacker specification for the first run (.atdl file)",
        "extension": ".atdl",
        "validation": { "must_exists": true },
        "default": "/home/alvie/spec-lib/example/attacker.atdl",
        "required": true
    },
    "--att-spec2": {
        "type": "filename",
        "description": "Path to second attacker specification for the second run (.atdl file)",
        "extension": ".atdl",
        "validation": { "must_exists": true },
        "default": "/home/alvie/spec-lib/example/attacker.atdl",
        "required": true
    }
}