{
    "Learn" : {
        "name" : "Learn",
        "description" : "Learn a Mealy machine model",
        "file" : "learn.exe",
        "args" : [
            {
                "description": "Path to attacker specification (.atdl file)",
                "flag": "--att-spec",
                "type": "filename",
                "default": "/home/alvie/spec-lib/example/attacker.atdl",
                "required": true
            },
            {
                "description": "Path to enclave specification (.etdl file)",
                "flag": "--encl-spec",
                "type": "filename",
                "default": "/home/alvie/spec-lib/example/enclave.etdl",
                "required": true
            },
            {
                "description": "Oracle that must be used for equivalence check",
                "flag": "--oracle",
                "type": "choice",
                "values" : ["randomwalk", "pac", "exhaustive"],
                "required": true
            },
            {
                "description": "Temporary directory where intermediate results will be stored",
                "flag": "--tmpdir",
                "type": "directory",
                "default": "/tmp/alvie",
                "required": true
            },
            {
                "description": "File where the final learned model will be stored (.dot file)",
                "flag": "--res",
                "type": "filename",
                "default": "/tmp/alvie/result.dot",
                "required": true
            },
            {
                "description": "Directory where the sancus-core-gap repository was cloned",
                "flag": "--sancus",
                "type": "directory",
                "default": "/home/alvie/sancus-core-gap",
                "required": true
            }
        ]
    },
    "Fa" : {
        "name" : "Fa",
        "description" : "Find flow-analysis (NI) violations between two models",
        "file" : "fa.exe"
    },
    "exit" : {
        "name" : "Exit"
    }
}